# Default behavior: treat files as text and normalize line endings.
* text=auto

# Keep source/config/docs with LF across platforms.
*.dart text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.gradle text eol=lf
*.kts text eol=lf
*.cmake text eol=lf
*.c text eol=lf
*.cc text eol=lf
*.h text eol=lf
*.swift text eol=lf
*.sh text eol=lf
*.plist text eol=lf

# Windows-native scripts should stay CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
